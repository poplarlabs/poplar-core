import { useState, useEffect, useCallback } from 'react';
import { useAccount, useReadContract, useWriteContract, useWaitForTransactionReceipt, useBalance, useConfig } from 'wagmi';
import { parseUnits, formatUnits, Address, erc20Abi, Abi } from 'viem';
import { useQueryClient, useQuery } from '@tanstack/react-query';
import { readContract as wagmiReadContract } from '@wagmi/core'; // Import core function

// --- ABI Imports ---
// Adjust paths based on your actual ABI output location after compiling contracts
// Ensure these files exist and export the ABI correctly (e.g., `export default { abi: [...] }`)
import SubmissionValidationJson from '../../contracts/out/SubmissionValidation.sol/SubmissionValidation.json';
import PoplarParametersJson from '../../contracts/out/PoplarParameters.sol/PoplarParameters.json';
// RootToken.json ABI is likely standard ERC20, but we import erc20Abi from viem

const SubmissionValidationABI = SubmissionValidationJson.abi as Abi;
const PoplarParametersABI = PoplarParametersJson.abi as Abi;

// --- Types ---
interface ApiConfig {
  rootTokenAddress?: string;
  poplarParametersAddress?: string;
  submissionValidationAddress?: string;
  treasuryAddress?: string;
  chainId?: string;
  rpcUrl?: string;
}

// --- Constants ---
const DEFAULT_DECIMALS = 18;
const API_BASE_URL = import.meta.env.VITE_API_BASE_URL || 'http://localhost:8000'; // Use env var for backend URL

export function usePoplarContract() {
  const { address: userAddress, isConnected, chain } = useAccount();
  const queryClient = useQueryClient();
  const wagmiConfig = useConfig(); // Get wagmi config for core actions

  const [config, setConfig] = useState<ApiConfig | null>(null);
  const [isLoadingConfig, setIsLoadingConfig] = useState(true);
  const [errorConfig, setErrorConfig] = useState<string | null>(null);

  // --- Fetch Backend Config ---
  useEffect(() => {
    let isMounted = true;
    async function fetchConfig() {
      setIsLoadingConfig(true);
      setErrorConfig(null);
      try {
        const response = await fetch(`${API_BASE_URL}/api/config`);
        if (!response.ok) {
          throw new Error(`Config fetch failed: ${response.status}`);
        }
        const data: ApiConfig = await response.json();
        if (isMounted) {
            setConfig(data);
            // Optionally validate received addresses/chain ID here
            if (!data.rootTokenAddress || !data.submissionValidationAddress || !data.poplarParametersAddress) {
                console.warn("One or more contract addresses missing in API config response");
                setErrorConfig("Incomplete configuration received from backend.");
            }
        }
      } catch (error: any) {
        console.error("Failed to fetch config:", error);
         if (isMounted) setErrorConfig(error.message || 'Failed to load configuration');
      } finally {
         if (isMounted) setIsLoadingConfig(false);
      }
    }
    fetchConfig();
    return () => { isMounted = false; }; // Cleanup on unmount
  }, []);

  // --- Derived Contract Addresses ---
  const rootTokenAddress = config?.rootTokenAddress as Address | undefined;
  const parametersAddress = config?.poplarParametersAddress as Address | undefined;
  const submissionValidationAddress = config?.submissionValidationAddress as Address | undefined;

  // Check if current chain matches expected chain from config (optional but recommended)
  const isCorrectChain = chain?.id === (config?.chainId ? parseInt(config.chainId, 10) : undefined);
  const hookEnabled = !!userAddress && !!submissionValidationAddress && !!rootTokenAddress && !!parametersAddress && isConnected && isCorrectChain;

  // --- Wagmi Hooks ---
  const { data: lastTxHash, error: writeError, isPending: isWritePending, writeContractAsync } = useWriteContract();
  const { isLoading: isTxLoading, isSuccess: isTxSuccess, error: txError, data: txReceipt } = useWaitForTransactionReceipt({ hash: lastTxHash });

  // --- ROOT Balance ---
  const { data: balanceData, refetch: refetchBalance, isLoading: isLoadingBalance } = useBalance({
    address: userAddress,
    token: rootTokenAddress,
    query: {
      enabled: !!userAddress && !!rootTokenAddress, // Enable only when needed addresses are available
    },
  });
  const rootBalance = balanceData?.value;
  const rootBalanceFormatted = balanceData?.formatted;

  // --- Read Contract Parameters (Using useQuery for better caching/state management) ---
  const useParameterRead = <T = unknown>(functionName: string, args: any[] = [], enabled = true) => {
    const queryKey = ['readParam', parametersAddress, functionName, chain?.id, JSON.stringify(args)];
    return useQuery<T, Error>({
      queryKey: queryKey,
      queryFn: async () => {
        if (!hookEnabled || !parametersAddress) throw new Error("Hook not ready or parameters address missing");
        return await wagmiReadContract(wagmiConfig, {
          address: parametersAddress,
          abi: PoplarParametersABI,
          functionName,
          args,
        }) as T;
      },
      enabled: hookEnabled && enabled,
      staleTime: 1000 * 60 * 5, // Cache parameters for 5 minutes
    });
  };

  const { data: sStakeAmount, refetch: refetchSStake, isLoading: isLoadingSStake } = useParameterRead<bigint>('sStakeAmount');
  const { data: valStakeAmount, refetch: refetchValStake, isLoading: isLoadingValStake } = useParameterRead<bigint>('valStakeAmount');
  // Example: Add other parameter reads if needed
  // const { data: consensusThreshold } = useParameterRead<bigint>('consensusThresholdPercent');

  // --- Read Allowance ---
   const { data: currentAllowance, refetch: refetchAllowance, isLoading: isLoadingAllowance } = useQuery<bigint, Error>({
    queryKey: ['allowance', rootTokenAddress, userAddress, submissionValidationAddress, chain?.id],
    queryFn: async () => {
        if (!hookEnabled || !rootTokenAddress || !userAddress || !submissionValidationAddress) throw new Error("Hook/addresses not ready for allowance check");
        return await wagmiReadContract(wagmiConfig, {
            address: rootTokenAddress,
            abi: erc20Abi,
            functionName: 'allowance',
            args: [userAddress, submissionValidationAddress],
        });
    },
    enabled: hookEnabled,
    staleTime: 1000 * 30, // Check allowance fairly often
  });


  // --- Approve Function ---
  const approveRootTokens = useCallback(async (spender: Address, amount: bigint) => {
    if (!rootTokenAddress || !isConnected) {
        console.error("Approve prerequisites not met");
        throw new Error("Cannot approve: Wallet not connected or token address missing.");
    }
    console.log(`Approving ${formatUnits(amount, DEFAULT_DECIMALS)} ROOT for ${spender}`);
    try {
      // Use writeContractAsync directly
      const txHash = await writeContractAsync({
        address: rootTokenAddress,
        abi: erc20Abi,
        functionName: 'approve',
        args: [spender, amount],
      });
      console.log("Approve transaction sent:", txHash);
      return txHash; // Return hash to wait for receipt externally if needed
    } catch (err: any) {
      console.error("Approve failed:", err);
      throw err; // Re-throw for handling in UI
    }
  }, [rootTokenAddress, isConnected, writeContractAsync]);

  // --- Check & Approve Helper ---
  const checkAndApprove = useCallback(async (requiredAmount: bigint): Promise<boolean> => {
     if (!hookEnabled || currentAllowance === undefined || !submissionValidationAddress) {
        throw new Error("Cannot check/approve: hook not ready or allowance unknown.");
     }
     console.log(`Checking allowance: Need ${formatUnits(requiredAmount, DEFAULT_DECIMALS)}, Have ${formatUnits(currentAllowance, DEFAULT_DECIMALS)}`);
     if (currentAllowance < requiredAmount) {
       try {
         console.log("Approval needed.");
         const approveHash = await approveRootTokens(submissionValidationAddress, requiredAmount); // Approve the required amount
         if (!approveHash) throw new Error("Approval failed to send");

         // Wait for approval confirmation using wagmi hook implicitly via lastTxHash
         // We need a way to know this specific hash finished. Let's handle waiting in the calling function.
         // Alternatively, could return the hash and let caller use useWaitForTransactionReceipt
         console.log(`Approval tx sent: ${approveHash}. Wait for confirmation before proceeding.`);
         // Returning true signifies approval *started*, not necessarily finished.
         // Ideally, wait for receipt in the calling function using the returned hash.
         // For simplicity here, we might just refetch allowance after a delay or rely on Tx success state.
         // Let's return the hash for explicit waiting.
         return approveHash; // Returning the hash indicates approval was needed and initiated

       } catch (err) {
         console.error("Approval process failed:", err);
         throw err; // Propagate error
       }
     } else {
       console.log("Sufficient allowance exists.");
       return false; // Returning false indicates no approval tx was needed
     }
   }, [hookEnabled, currentAllowance, submissionValidationAddress, approveRootTokens]);

  // --- Core Write Functions ---

  const submitData = useCallback(async (dataPointer: string) => {
    if (!hookEnabled || sStakeAmount === undefined) {
        throw new Error("Cannot submit: hook not ready or stake amount unknown.");
    }
    const stake = sStakeAmount;
    console.log(`Attempting submission: ${dataPointer}, Stake: ${formatUnits(stake, DEFAULT_DECIMALS)}`);

    try {
      const approveNeededHash = await checkAndApprove(stake);
      if (approveNeededHash) {
          // Wait for the approval TX
          console.log(`Waiting for approval TX ${approveNeededHash} to complete...`);
          // This requires a local wait or a UI update telling user to wait.
          // For robust UX, disable submit button until approval receipt is confirmed success.
          // Simplified: Assume user waits or handle this state in UI based on lastTxHash & isTxSuccess
          // Let's just throw an error for now if we detect the approval hash is the last one and it's pending/failed.
          // A better approach involves managing tx states more granularly.
          alert("Approval transaction sent. Please wait for confirmation and try submitting again."); // Simple feedback
          // Re-query allowance after a delay could also work.
          setTimeout(() => refetchAllowance(), 5000); // Refetch after 5s
          throw new Error("Approval required. Wait for confirmation.");
      }

      // Proceed with submission if approval wasn't needed or assumed complete
      console.log("Calling submitData contract function...");
      return await writeContractAsync({
        address: submissionValidationAddress!,
        abi: SubmissionValidationABI,
        functionName: 'submitData',
        args: [dataPointer],
      });
    } catch (err: any) {
      console.error("submitData failed:", err);
      throw err;
    }
  }, [hookEnabled, sStakeAmount, checkAndApprove, writeContractAsync, submissionValidationAddress, refetchAllowance]);

  const castVote = useCallback(async (submissionId: bigint, voteChoice: boolean) => {
     if (!hookEnabled || valStakeAmount === undefined) {
         throw new Error("Cannot vote: hook not ready or stake amount unknown.");
     }
    const stake = valStakeAmount;
    console.log(`Attempting vote: ${submissionId}, Choice: ${voteChoice}, Stake: ${formatUnits(stake, DEFAULT_DECIMALS)}`);

    try {
       const approveNeededHash = await checkAndApprove(stake);
        if (approveNeededHash) {
            alert("Approval transaction sent. Please wait for confirmation and try voting again.");
            setTimeout(() => refetchAllowance(), 5000);
            throw new Error("Approval required. Wait for confirmation.");
        }

      // Proceed with vote
      console.log("Calling castVote contract function...");
      return await writeContractAsync({
        address: submissionValidationAddress!,
        abi: SubmissionValidationABI,
        functionName: 'castVote',
        args: [submissionId, voteChoice],
      });
    } catch (err: any) {
      console.error("castVote failed:", err);
      throw err;
    }
  }, [hookEnabled, valStakeAmount, checkAndApprove, writeContractAsync, submissionValidationAddress, refetchAllowance]);

  const finalizeValidation = useCallback(async (submissionId: bigint) => {
     if (!hookEnabled || !submissionValidationAddress) {
         throw new Error("Cannot finalize: hook not ready.");
     }
    console.log(`Attempting finalize validation: ${submissionId}`);
    try {
      // No approval needed for finalize
      console.log("Calling finalizeValidation contract function...");
      return await writeContractAsync({
        address: submissionValidationAddress,
        abi: SubmissionValidationABI,
        functionName: 'finalizeValidation',
        args: [submissionId],
      });
    } catch (err: any) {
      console.error("finalizeValidation failed:", err);
      throw err;
    }
  }, [hookEnabled, writeContractAsync, submissionValidationAddress]);

  // --- Refetching ---
  const refetchAll = useCallback(() => {
    console.log("Refetching Poplar contract data...");
    refetchBalance();
    refetchSStake();
    refetchValStake();
    refetchAllowance();
    // Invalidate queries related to submissions/votes if using react-query for lists
    // queryClient.invalidateQueries({ queryKey: ['submissions'] });
  }, [refetchBalance, refetchSStake, refetchValStake, refetchAllowance, queryClient]);

  // Effect to refetch data after a successful transaction
  useEffect(() => {
    if (isTxSuccess && lastTxHash) {
        console.log(`Transaction ${lastTxHash} successful, refetching data.`);
        refetchAll();
    }
  }, [isTxSuccess, lastTxHash, refetchAll]);


  // --- Return Values ---
  return {
    // Config state
    config,
    isLoadingConfig,
    errorConfig,
    // Contract addresses
    rootTokenAddress,
    parametersAddress,
    submissionValidationAddress,
    // User state
    userAddress,
    isConnected,
    isCorrectChain,
    rootBalance,
    rootBalanceFormatted,
    isLoadingBalance,
    // Parameters
    sStakeAmount,
    valStakeAmount,
    isLoadingParameters: isLoadingSStake || isLoadingValStake, // Example combined loading
    // Allowance
    currentAllowance,
    isLoadingAllowance,
    refetchAllowance,
    // Write functions
    submitData,
    castVote,
    finalizeValidation,
    // Transaction state (for the last triggered write)
    lastTxHash,
    isTxLoading,       // Loading state for the *last* transaction hash
    isTxSuccess,       // Success state for the *last* transaction hash
    txReceipt,         // Receipt for the *last* transaction hash
    txError,           // Error related to waiting for the receipt
    writeError,        // Error from initiating the write call
    isWritePending,    // Is a write call currently pending user confirmation/sending
    // Refetch
    refetchBalance,
    refetchAll,
    // Readiness check
    isReady: hookEnabled,
  };
}
